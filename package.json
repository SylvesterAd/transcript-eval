{
  "name": "transcript-eval",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env --watch-path=server/index.js --watch-path=server/routes --watch-path=server/services server/index.js",
    "start": "node server/index.js",
    "build": "if [ \"$RAILWAY_ENVIRONMENT\" ]; then echo 'Railway: skip frontend build'; else vite build; fi",
    "seed": "node server/seed/import-benchmark.js",
    "seed:strategies": "node server/seed/create-strategies.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ext:generate-key": "node extension/scripts/generate-key.mjs"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.3.2",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.100.0",
    "@waveform-playlist/browser": "^11.2.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "diff": "^7.0.0",
    "express": "^5.1.0",
    "hls.js": "^1.6.15",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "openai": "^6.29.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.0",
    "semver": "^7.6.0",
    "sql.js": "^1.11.0",
    "styled-components": "^6.3.12",
    "tone": "^15.1.22",
    "tus-js-client": "^4.3.1",
    "ulid": "^3.0.2",
    "undici": "^7.24.4",
    "waveform-data": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0",
    "vitest": "^1.6.1"
  }
}
