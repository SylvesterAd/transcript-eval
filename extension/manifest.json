{
  "manifest_version": 3,
  "name": "transcript-eval Export Helper",
  "version": "0.9.0",
  "description": "Export your transcript-eval projects to Premiere with b-rolls from your own subscription accounts.",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "tabs", "webNavigation", "downloads", "cookies", "power"],
  "host_permissions": [
    "https://elements.envato.com/*",
    "https://app.envato.com/*",
    "https://video-downloads.elements.envatousercontent.com/*",
    "https://videos.pexels.com/*",
    "https://images.pexels.com/*",
    "https://*.freepik.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "http://localhost:5174/*",
      "https://transcript-eval.com/*"
    ]
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "key": ""
}
